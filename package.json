{
  "name": "plugidle",
  "version": "1.1.5",
  "description": "PlugIdle — a retro CRT idle game about plugging in every type of cord imaginable.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:www": "node scripts/build-www.mjs",
    "bump": "node scripts/bump-version.mjs",
    "sync": "npm run build:www && cap sync android",
    "open:android": "cap open android",
    "android": "npm run sync && npm run open:android",
    "sync:ios": "npm run build:www && cap sync ios",
    "open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/status-bar": "^8.0.2",
    "cordova-plugin-purchase": "^13.16.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0"
  }
}
